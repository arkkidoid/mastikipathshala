# SMTP — Hostinger email (copy to .env.local for local dev; add to Vercel for prod)
# Only SMTP_PASS is strictly required; the rest have sensible defaults.

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@mastikipaathshaala.org
SMTP_PASS=your-mailbox-password-here

# Where form submissions get delivered (defaults to SMTP_USER)
MAIL_TO=hello@mastikipaathshaala.org

# ---- CMS / Manager dashboard (/manager) ----
# MongoDB Atlas connection string + database name
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=MKP
MONGODB_DB=mkp

# Single admin login for the dashboard
ADMIN_EMAIL=admin@arkkidoid.in
ADMIN_PASSWORD=change-this-to-a-strong-password

# Long random string used to sign login sessions (openssl rand -base64 48)
AUTH_SECRET=replace-with-a-long-random-secret
